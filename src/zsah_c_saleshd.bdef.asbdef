projection;
strict ( 2 );
use draft;

define behavior for ZSAH_C_SALESHD alias Header
{
  use create;
  use update;
  use delete;

  use action Edit;
  use action Resume;
  use action Prepare;
  use action Activate;
  use action Discard;

  use association _Salesitem { create; with draft; }
}

define behavior for ZSAH_C_SALESITM alias Item
{
  use update;
  use delete;

  use association _SalesHeader { with draft; }
}